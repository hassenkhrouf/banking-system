# ========================================
# Banking System — Environment Variables
# Copy this file to .env and adjust values
# ========================================

# Database
DB_URL=jdbc:postgresql://localhost:5432/banking_db
DB_USERNAME=postgres
DB_PASSWORD=postgres

# JWT (generate your own secret for production)
# Use: openssl rand -base64 64
JWT_SECRET=ZmFudGFzdGljLXNlY3JldC1rZXktZm9yLWJhbmtpbmctc3lzdGVtLW11c3QtYmUtbG9uZy1hbmQtc2VjdXJlLWZvci1oczI1Ng==
JWT_EXPIRATION_MS=900000
JWT_REFRESH_EXPIRATION_MS=604800000

# Logging
LOG_LEVEL=INFO
SHOW_SQL=false
HIBERNATE_FORMAT_SQL=false
